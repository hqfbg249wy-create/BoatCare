# Skipily Provider Portal — Beispiel-Environment
#
# Lokal: Kopiere diese Datei zu ".env.local" und traege Deine Werte ein.
# Vercel: Diese Variablen unter "Settings > Environment Variables"
#         im Vercel-Dashboard fuer das Projekt hinterlegen.

# Supabase Projekt-URL (aus Supabase Dashboard > Project Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon / public key (KEIN service role key!)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
