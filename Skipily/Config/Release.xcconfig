// Skipily - Release build configuration
// Attach in Xcode: Project > Info > Configurations > Release > set to Release.xcconfig
//
// IMPORTANT: Replace with your LIVE Stripe publishable key before shipping.
// Live keys start with pk_live_. Never commit secret keys (sk_live_/sk_test_).
STRIPE_PUBLISHABLE_KEY = pk_live_REPLACE_ME_BEFORE_RELEASE

// Supabase (production)
// SUPABASE_URL = https://YOUR-PROJECT.supabase.co
// SUPABASE_ANON_KEY = eyJ...

// Build settings
SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited)
