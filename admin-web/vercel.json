{
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/((?!api|_next|favicon|.*\\..*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
